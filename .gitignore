backups/
.claude/*
!.claude/agents/

# Visual asset binaries — only ignored for fresh drops; files already
# committed (via web upload or explicit `git add -f`) stay tracked. The
# game expects manifest paths to resolve to files on disk, so binaries
# DO live in git for the production game; the ignore rules just keep
# random local downloads from being added by accident.
assets/hdri/*.hdr
assets/textures/**/*.jpg
assets/textures/**/*.jpeg
assets/textures/**/*.png
assets/models/**/*.glb
assets/models/**/*.gltf
assets/models/**/*.bin
assets/models/**/*.obj
assets/models/**/*.mtl
assets/models/**/*.fbx
# Texture files inside models/ folders (referenced via .mtl from .obj
# loaders, or embedded textures alongside .fbx, or shared bark/leaf .png
# next to .gltf nature props).
assets/models/**/*.jpg
assets/models/**/*.jpeg
assets/models/**/*.png
assets/models/**/*.tga

# Asset inbox — temp drop zone, contents never auto-committed (only the
# README + .gitkeep stay tracked so the folder exists in fresh clones).
assets/_inbox/*
!assets/_inbox/README.md
!assets/_inbox/.gitkeep

# Perf Phase A: runner output (raw JSON) — niet committen, regenereerbaar
# via tools/perf-run.mjs. Het rapport (PERF_PHASE_A_REPORT.md) blijft wél
# tracked zodat we 'm kunnen reviewen.
tools/perf-output.json

# Werk-documentatie / planning — lokaal houden, niet publiceren
CLAUDE.md
CLAUDE_CODE_PROMPTS.md
REFACTOR_PLAN.md
PHASE_0_1.md
PHASE_2.md
PHASE_3_4.md
MUSIC_CHANGES.md
VOLCANO_PILOT_PROMPT.md
WORLDS_SIGNATURE_PROMPTS.md
