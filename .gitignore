backups/
.claude/*
!.claude/agents/

# Visual asset binaries — only ignored for fresh drops; files already
# committed (via web upload or explicit `git add -f`) stay tracked. The
# game expects manifest paths to resolve to files on disk, so binaries
# DO live in git for the production game; the ignore rules just keep
# random local downloads from being added by accident.
assets/hdri/*.hdr
assets/textures/**/*.jpg
assets/textures/**/*.jpeg
assets/textures/**/*.png
assets/models/**/*.glb
assets/models/**/*.gltf
assets/models/**/*.bin
assets/models/**/*.obj
assets/models/**/*.mtl
assets/models/**/*.fbx
# Texture files inside models/ folders (referenced via .mtl from .obj
# loaders, or embedded textures alongside .fbx, or shared bark/leaf .png
# next to .gltf nature props).
assets/models/**/*.jpg
assets/models/**/*.jpeg
assets/models/**/*.png
assets/models/**/*.tga

# Asset inbox — temp drop zone, contents never auto-committed (only the
# README + .gitkeep stay tracked so the folder exists in fresh clones).
assets/_inbox/*
!assets/_inbox/README.md
!assets/_inbox/.gitkeep

# ── Dev-workspace blanket rules ───────────────────────────────────────
# All DEV-WORKSPACE markdowns and tooling live in the private
# properams/srclub-workspace repo. The patterns below prevent accidental
# leakage of new dev-context into the public repo.

# Root-level *.md files are dev-workspace by default — only the public
# README.md is allowed in the repo root.
/*.md
!/README.md

# tools/ is dev-only (perf-runners + screenshots + baselines)
/tools/

# docs/ — the only files we keep public are .gitkeep markers if any.
# Anything else (CINEMATIC_PATTERN, SESSION_HANDOVER, PRIVACY_AUDIT)
# belongs in the private workspace.
/docs/SESSION_HANDOVER.md
/docs/PRIVACY_AUDIT_REPORT.md
/docs/CINEMATIC_PATTERN.md

# Common cruft
.DS_Store
node_modules/
*.log
