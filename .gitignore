backups/
.claude/*
!.claude/agents/

# Visual asset binaries — downloaded via assets/download_assets.sh.
# Never commit; redistributable from source on demand.
assets/hdri/*.hdr
assets/textures/**/*.jpg
assets/textures/**/*.jpeg
assets/textures/**/*.png
assets/models/**/*.glb
assets/models/**/*.gltf

# Asset inbox — temp drop zone, contents never committed (only the
# README + .gitkeep stay tracked so the folder exists in fresh clones).
assets/_inbox/*
!assets/_inbox/README.md
!assets/_inbox/.gitkeep

